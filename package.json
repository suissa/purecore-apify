    "demo:schemas": "tsx examples/zod-schema-generation.ts",
    "demo:fastify": "tsx examples/fastify-integration.ts",
    "dev:fastify": "tsx examples/advanced-fastify-decorators.ts"
  },
  "devDependencies": {
    "@types/cookie": "^0.5.1",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@purecore/reqify": "latest",
    "cookie": "^1.0.2",
    "i18next": "^23.7.6",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4"
  }
}
